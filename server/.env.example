# PostgreSQL (Neon Tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# xAI Grok API
XAI_API_KEY=your_xai_api_key_here
XAI_API_ENDPOINT=https://api.x.ai/v1/chat/completions

# Admin
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Calendly
CALENDLY_LINK=https://calendly.com/your-link

# GDPR / Consent
CONTACT_CONSENT_TEXT=I agree to be contacted by Ichnos Protocol regarding my enquiry. My contact details and questions will be stored securely and used solely for the purpose of responding to my enquiry and for internal analytics under legitimate interest.
CONTACT_CONSENT_VERSION=v1
PRIVACY_POLICY_URL=https://ichnos-protocol.vercel.app/privacy

# Email (Resend)
RESEND_API_KEY=re_your_resend_key_here

# Security
CORS_ORIGIN=https://ichnos-protocol.vercel.app
CRON_SECRET=your_cron_secret_here

# Server
PORT=3000
NODE_ENV=development

# Python PDF Conversion (optional, for knowledge base scripts)
MARKER_USE_LLM=false
MARKER_DEFAULT_DPI=200
