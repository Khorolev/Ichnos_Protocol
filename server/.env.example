# PostgreSQL (Neon Tech)
DATABASE_URL=postgresql://user:password@host:5432/database

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# xAI API
XAI_API_KEY=your_xai_api_key_here
XAI_API_ENDPOINT=https://api.x.ai/v1/chat/completions

# Admin
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Calendly
CALENDLY_LINK=https://calendly.com/your-link

# GDPR / Consent
CONTACT_CONSENT_TEXT=I agree to be contacted regarding my enquiry and for internal statistics.
CONTACT_CONSENT_VERSION=v1
PRIVACY_POLICY_URL=https://ichnos-protocol.com/privacy

# Email (Resend)
RESEND_API_KEY=re_your_resend_key_here

# Security
CORS_ORIGIN=https://ichnos-client.vercel.app
CRON_SECRET=

# E2E test seeding (auto-seeds in preview environments via seedE2EOnPreview.js)
E2E_ADMIN_EMAIL=             # Admin test account email (required for auto-seed in preview)
E2E_ADMIN_UID=               # Admin test account Firebase UID (required for auto-seed in preview)
E2E_USER_EMAIL=              # Regular user test account email (optional)
E2E_USER_UID=                # Regular user test account Firebase UID (optional)
E2E_SUPER_ADMIN_EMAIL=       # Super-admin test account email (optional)
E2E_SUPER_ADMIN_UID=         # Super-admin test account Firebase UID (optional)

# Server
NODE_ENV=production
