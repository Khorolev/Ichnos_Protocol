# =============================================================================
# E2E Test Credentials Template
# =============================================================================
#
# Usage:
#   1. Copy this file to .env.e2e:       cp .env.e2e.example .env.e2e
#   2. Fill in the email and password fields for each role you want to test.
#   3. Leave UID fields blank — they are filled automatically during provisioning.
#   4. Run the provision script:          node scripts/provision-e2e-firebase-users.js
#      Or sync-only (skip Firebase):     node scripts/provision-e2e-firebase-users.js --sync-only
#
# Notes:
#   - Admin credentials are REQUIRED. User and Super-Admin are optional.
#   - For optional roles: provide BOTH email and password, or leave BOTH blank.
#   - UIDs are written back to this file automatically after Firebase provisioning.
#   - This script is a LOCAL/MANUAL developer/admin tool — run from your own machine,
#     not by CI or E2E workflows. ci.yml and e2e.yml consume the synced outputs only.
#   - Behavior depends on your local environment: CLI installation/PATH, gh and vercel
#     CLI auth state, server/.vercel/project.json linkage, and shell/terminal session.
#   - Troubleshooting terminal-related failures:
#       1. Confirm you are running from the repo root
#       2. gh auth status
#       3. vercel whoami
#       4. cd server && vercel link (must link to ichnos-protocolserver)
#

# ----- Admin (REQUIRED) -----
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_ADMIN_UID=                # Auto-filled by provisioning script

# ----- User (OPTIONAL — provide both email and password, or leave both blank) -----
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_USER_UID=                 # Auto-filled by provisioning script

# ----- Super Admin (OPTIONAL — provide both email and password, or leave both blank) -----
E2E_SUPER_ADMIN_EMAIL=
E2E_SUPER_ADMIN_PASSWORD=
E2E_SUPER_ADMIN_UID=          # Auto-filled by provisioning script
