# Firebase Client SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Calendly
VITE_CALENDLY_URL=https://calendly.com/your-link

# API host (Vercel rewrite target — substituted in client/vercel.json at request time
# from a build-time env-var snapshot).
#
# On Vercel: set as a single entry with Environments = "Production and Preview",
# no custom branch override. The existing staging branch override stays in place
# (branch-scoped values outrank the default).
#
#   Production                           : api.ichnos-protocol.com
#   Preview (default — main, features)   : api.ichnos-protocol.com
#   Preview / branch=staging (override)  : staging-api.ichnos-protocol.com
#
# Trap: setting only Production scope LOOKS correct and survives a manual
# Vercel "Redeploy" — but `promote-to-production.yml` uses `vercel promote`,
# which re-aliases an existing preview build without rebuilding. That preview
# was built with PREVIEW scope, so the Production-only configuration is
# silently ignored by the workflow and production regresses to
# `502 DNS_HOSTNAME_NOT_FOUND` on the next promotion. See Tier 8a in
# docs/deploymentMigrationValidation.md and lesson E5 in devOpsLessonsLearned.md.
VITE_API_HOST=api.ichnos-protocol.com
