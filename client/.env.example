# Firebase Client SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Calendly
VITE_CALENDLY_URL=https://calendly.com/your-link

# API host (Vercel rewrite target — substituted in vercel.json at deploy time).
# MUST be set on Vercel client project for BOTH Production AND Preview scopes:
#   - Production scope: api.ichnos-protocol.com
#   - Preview scope (default):   the latest preview deployment of the server,
#     or staging-api.ichnos-protocol.com if you have branch-scoped overrides.
# Setting only Preview is the post-migration trap: staging will work, production
# will return `502 DNS_HOSTNAME_NOT_FOUND` because the rewrite resolves to "".
VITE_API_HOST=api.ichnos-protocol.com
