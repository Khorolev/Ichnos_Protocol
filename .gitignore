# ============================================
# Secrets and credentials — NEVER commit these
# ============================================
.env
.env.*
!.env.example
!.env.e2e.example
# E2E config: non-sensitive values (test emails, UIDs, Firebase API key), safe to commit
!e2e/.env.e2e
*.pem
*.key
*.p12
*.pfx
*.crt
*-service-account*.json
firebase-service-account*.json
serviceAccountKey*.json
credentials*.json
# Firebase admin SDK key files — catch current and historical filename variants
# (e.g. *_staging.json, *_test.json, date-tagged keys) instead of exact names.
.ichnos-protocol-*firebase-adminsdk*.json
*firebase-adminsdk*.json
secrets/

# ============================================
# MCP configuration (machine and project-specific, may contain secrets)
# ============================================
.mcp.json

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp/
.pnp.js

# ============================================
# Build output
# ============================================
dist/
build/
.output/
.vercel/

# ============================================
# Test output
# ============================================
coverage/
playwright-report/
test-results/
blob-report/
e2e/.auth/

# ============================================
# IDE and editor files
# ============================================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# OS files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ============================================
# Logs
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Claude CLI (local settings are machine-specific)
# ============================================
.claude/settings.local.json

# ============================================
# Knowledge base PDFs (large binaries, proprietary sources)
# ============================================
server/knowledge-base/pdfs/

# ============================================
# Knowledge base pipeline artifacts
# ============================================
server/knowledge-base/markdown_output/
.state/
.pipeline.lock
.logs/

# ============================================
# Misc
# ============================================
*.tsbuildinfo
.eslintcache
*.local
nul
